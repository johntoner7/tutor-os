# LLM provider: anthropic | deepseek
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# DeepSeek (required when LLM_PROVIDER=deepseek)
# LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

PINECONE_API_KEY=
ALLOWED_ORIGINS=http://localhost:5173

# Database — omit to use local SQLite; set for hosted Postgres (Supabase/Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Subjects are configured via data/{subject_id}/subject_config.json
# Add a new directory with a subject_config.json to add a new subject
